# Copy to .env and fill in values. Never commit .env.

# Required: JWT signing secret for auth tokens.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
DONORPIPE_JWT_SECRET=

# Optional: Stripe API key for automated downloads (M19b).
# Used by scripts/build_graphs.sh and src/donorpipe/downloads/runner.py.
# If unset, the Stripe download step is silently skipped.
STRIPE_API_KEY=sk_live_...
